# ============================================================
# Maya AI Sales Engine - Environment Variables
# Copy this file to .env and fill in your real credentials
# NEVER commit .env to git
# ============================================================

# --- OpenAI ---
OPENAI_API_KEY=sk-...your-openai-api-key-here...

# --- Microsoft Graph API (for maya@makeyourlabel.com) ---
MICROSOFT_TENANT_ID=your-tenant-id-here
MICROSOFT_CLIENT_ID=your-client-id-here
MICROSOFT_CLIENT_SECRET=your-client-secret-here
MAYA_EMAIL=maya@makeyourlabel.com

# --- Zoho CRM API ---
ZOHO_CLIENT_ID=your-zoho-client-id-here
ZOHO_CLIENT_SECRET=your-zoho-client-secret-here
ZOHO_REFRESH_TOKEN=your-zoho-refresh-token-here
ZOHO_BASE_URL=https://www.zohoapis.in/crm/v2
ZOHO_ORG_ID=60057163213

# --- App Settings ---
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENV=production

# --- Webhook Security ---
WEBHOOK_SECRET=your-random-webhook-secret-here

# --- Conversation Settings ---
MAX_CONVERSATION_TURNS=20
RESPONSE_DELAY_SECONDS=30
